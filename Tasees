<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>نظام توكيلات تأسيس</title>
    <style>
        :root {
            --primary: #1a2a3a;
            --secondary: #27ae60;
            --accent: #e74c3c;
            --info: #3498db;
            --bg: #f4f7f6;
        }

        body, html {
            margin: 0; padding: 0; height: 100%; overflow: hidden;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: var(--bg);
        }

        .app-container {
            display: flex; flex-direction: column;
            height: 100vh; max-width: 500px; margin: auto;
            background: white;
        }

        .header { background: var(--primary); color: white; padding: 5px; text-align: center; flex-shrink: 0; }
        .header h5 { margin: 5px 0; font-size: 0.85rem; }

        /* منطقة الفاتورة */
        .invoice-box {
            height: 25vh; 
            background: #fffdf2; border-bottom: 2px solid #f1c40f;
            display: flex; flex-direction: column; overflow: hidden; flex-shrink: 0;
        }

        .table-scroll { flex: 1; overflow-y: auto; }
        .invoice-table { width: 100%; border-collapse: collapse; font-size: 0.7rem; }
        .invoice-table th { background: #f1c40f; padding: 4px; position: sticky; top: 0; z-index: 10; }
        .invoice-table td { padding: 4px 2px; text-align: center; border-bottom: 1px solid #eee; }

        .total-row {
            background: #fef9e7; padding: 5px; text-align: center;
            font-weight: bold; color: var(--accent); font-size: 0.85rem; flex-shrink: 0;
        }

        .controls { padding: 6px; display: flex; flex-direction: column; gap: 4px; flex-shrink: 0; }
        .search-row { display: flex; gap: 4px; }
        input[type="text"] { flex: 1; padding: 8px; border-radius: 6px; border: 1px solid #ddd; outline: none; font-size: 0.8rem; }
        .btn-browse { padding: 0 10px; border-radius: 6px; border: none; color: white; font-weight: bold; cursor: pointer; font-size: 0.75rem; }

        /* منطقة الأصناف */
        .items-scroll-container {
            flex: 1;
            margin: 0 6px;
            padding: 4px;
            background: #f0f2f5;
            border: 1px solid #ddd;
            border-radius: 8px;
            overflow-y: auto;
        }

        .item-row {
            background: white; margin-bottom: 3px; padding: 5px;
            border-radius: 4px; display: flex; align-items: center;
            border: 1px solid #eee; font-size: 0.75rem;
        }

        .item-info { flex: 1; cursor: pointer; }
        .qty-input { width: 35px; padding: 2px; text-align: center; border-radius: 4px; border: 1px solid #ccc; font-size: 0.75rem; }

        /* تعديل منطقة الزر لتكون مرتفعة عن الحافة */
        .footer-action {
            padding: 10px 10px 30px 10px; /* زيادة الهامش السفلي لرفع الزر */
            background: #fff;
            border-top: 1px solid #eee;
            flex-shrink: 0;
            box-shadow: 0 -4px 10px rgba(0,0,0,0.05);
        }

        .send-btn {
            width: 100%; padding: 14px; background: var(--secondary);
            color: white; border: none; border-radius: 10px;
            font-size: 1rem; font-weight: bold; cursor: pointer;
        }

        .modal {
            position: fixed; inset: 0; background: rgba(0,0,0,0.8);
            display: none; justify-content: center; align-items: center; z-index: 2000;
        }
        .modal-content { background: white; padding: 15px; border-radius: 15px; width: 80%; text-align: center; }
        .staff-btn { display: block; width: 100%; padding: 12px; margin: 8px 0; color: white; border: none; border-radius: 8px; font-weight: bold; font-size: 0.9rem; }
    </style>
</head>
<body>

<div class="app-container">
    <div class="header"><h5>توكيلات تأسيس الطبية</h5></div>

    <div class="invoice-box">
        <div class="table-scroll">
            <table class="invoice-table">
                <thead>
                    <tr>
                        <th style="width:45%">الصنف</th>
                        <th>السعر</th>
                        <th style="width:12%">العدد</th>
                        <th>إجمالي</th>
                        <th style="width:8%">✕</th>
                    </tr>
                </thead>
                <tbody id="cartItems"></tbody>
            </table>
        </div>
        <div class="total-row" id="grandTotal">الإجمالي: 0 SDG</div>
    </div>

    <div class="controls">
        <div class="search-row">
            <input type="text" id="itemSearch" placeholder="🔍 ابحث هنا..." oninput="filterItems()">
            <button id="browseBtn" class="btn-browse" style="background:var(--info);" onclick="toggleBrowse()">تصفح</button>
        </div>
    </div>

    <div class="items-scroll-container" id="itemsWrapper">
        <div style="text-align:center; padding:15px; color:#bbb; font-size: 0.7rem;">اضغط تصفح للأصناف</div>
    </div>

    <div class="footer-action">
        <button class="send-btn" onclick="openStaffModal()">إرسال الطلبية واتساب ✅</button>
    </div>
</div>

<div class="modal" id="staffModal" onclick="this.style.display='none'">
    <div class="modal-content" onclick="event.stopPropagation()">
        <h4 style="margin:0 0 10px 0;">إرسال إلى:</h4>
        <button class="staff-btn" style="background:#8e44ad" onclick="sendToWA('23586624931', 'دكتور الأمين')">⚕️ دكتور الأمين</button>
        <button class="staff-btn" style="background:#2980b9" onclick="sendToWA('14422310941', 'باش مهندس عبدالرحمن')">⚙️ باش مهندس عبدالرحمن</button>
        <button class="staff-btn" style="background:#d35400" onclick="sendToWA('249123594182', 'أستاذ ناصر')">💼 أستاذ ناصر</button>
    </div>
</div>

<script>
    // تم الإبقاء على مصفوفة البيانات والوظائف كما هي لضمان عمل البرنامج
    const masterData = [{n:"Allopurinol 100",p:2000},{n:"Allopurinol 300",p:2500},{n:"Amiciprox Eye Drop",p:4000},{n:"Amidol tab 5st",p:1500},{n:"Amiprazol Cap",p:6000},{n:"Amixime 100mg 30ml",p:3500},{n:"Amlo 10",p:3300},{n:"Amlo 5",p:3000},{n:"Amoclan 1g",p:6000},{n:"Amoclan 1g 14s",p:7000},{n:"Amoclan 625mg",p:5800},{n:"Amoxicillin 125mg/5ml",p:2200},{n:"AMOXIL CAPS",p:12000},{n:"Amoxy-250 CAP",p:8000},{n:"Artemether 80mg",p:22000},{n:"ARTESNEN 180",p:3500},{n:"ARTESUNATE 30",p:1600},{n:"ARTESUNATE 60",p:1600},{n:"Asprin 100mg",p:11000},{n:"Asprin 75",p:10000},{n:"Atorvastatin 20mg",p:1400},{n:"Azimax 250mg",p:2500},{n:"AZIMAX 500",p:1500},{n:"Azithromycin 200 sy",p:2400},{n:"Baby Powder 50mg",p:3300},{n:"Benzyl Benzoate",p:2000},{n:"Benzyl penicillin",p:400},{n:"Betamethasone Cream",p:2000},{n:"Biscodyl 5mg tap",p:7000},{n:"Bisoprolol 2.5 mg",p:1000},{n:"Bisoprolol 5 mg",p:1600},{n:"Cabamatol 200mg tap",p:14000},{n:"Candid-B",p:2500},{n:"Canula 18",p:55000},{n:"Canula 20",p:55000},{n:"Canula 22",p:55000},{n:"Canula 26",p:55000},{n:"Cat cat 2/0",p:25000},{n:"Cefixime 400mg Cap",p:3200},{n:"Cefodox 100mg susp",p:4000},{n:"Cefodox 200",p:3800},{n:"Ceftriaxone 1g inj",p:1500},{n:"Cephalexin 125",p:3300},{n:"Cetrizin Syp",p:2000},{n:"Cetrizin Tap",p:4000},{n:"Chloramphenicol 125ml",p:2800},{n:"Chlorpheniramine inj",p:750},{n:"Chlorphenramine 4mg",p:4000},{n:"Chlorphenramine Syrp",p:2200},{n:"Ciprofloxacin tab 500mg",p:10000},{n:"Clomifene Citrate 50mg",p:2500},{n:"Clotrmazol 100mg supp",p:3500},{n:"COLD B FLU",p:10000},{n:"COMTHER 6",p:1500},{n:"DACOF PD",p:3000},{n:"DEXA SYR 120ML",p:4000},{n:"Dexa. Eye drop",p:3500},{n:"Dexamethasone Inj",p:800},{n:"diazpam 5ml",p:10000},{n:"Diclofenac 50mg",p:2500},{n:"Diclofenac 50mg potasum",p:4000},{n:"Diclofenac gel craem",p:2500},{n:"Diclofenac 75mg",p:3000},{n:"DOXYCYCLINE 100mg",p:10000},{n:"Esomeprazole40",p:1700},{n:"Examination gloves",p:15000},{n:"family contraceptives",p:4000},{n:"FEROFOL tab",p:10000},{n:"Finasteride Tablets",p:1500},{n:"FLOCLAV 228MG",p:3500},{n:"Folic Acid 5mg",p:4000},{n:"Furesemide inj",p:1000},{n:"Gause bandage 5cm",p:4500},{n:"Gause bandage 7.5CM",p:6000},{n:"GAUZE ROOL 90*90",p:60000},{n:"Gentamicin eye/ear Drop",p:1200},{n:"Gentamycin inj",p:800},{n:"Glimerpiride 2mg",p:10000},{n:"Grisofulvin 500mg tap",p:3000},{n:"Hydrocortisone cream",p:2500},{n:"Hyocine inj",p:1200},{n:"IBU 400",p:6000},{n:"Ibuprofen 200",p:5000},{n:"Ibuprofen 100 syerp",p:1800},{n:"Malaria Test ICT",p:35000},{n:"Indomethacin Cap",p:8000},{n:"Ketoconazole cream 20gm",p:2000},{n:"LANCETS",p:5500},{n:"Letrozole 2.5mg",p:1600},{n:"Levofloxacin 500",p:4000},{n:"Levofloxacin IV",p:3500},{n:"Lopramaid 2 mg cap",p:7000},{n:"loratadine 10 mg",p:1700},{n:"Mefenamic Acid 500 mg",p:9000},{n:"Mefnamic acid syerp",p:1800},{n:"Meropenum inj",p:7000},{n:"Meteclopromide inj",p:700},{n:"Metronidazole 250",p:4500},{n:"Metronidazole 125mg",p:2300},{n:"Metronidazole 500mg",p:6000},{n:"Multivitamin",p:4000},{n:"Nefopam Hcl 20mg",p:1500},{n:"Norethistrrone 5 mg",p:1700},{n:"NYALON 2/0",p:20000},{n:"Nystatin drop",p:3000},{n:"Ofloxacin 400mg",p:3500},{n:"olanzepin 10mg",p:8000},{n:"PARACITMOL tap",p:3000},{n:"PARACITMOL SYR",p:1500},{n:"Pantoprazole 20",p:10000},{n:"Pantoprazole 40mg",p:13000},{n:"Paraffin gauze",p:13000},{n:"Povidone iodine 100ml",p:5000},{n:"POVIDONE IODINE 200ML",p:7000},{n:"Praziquantel 600mg",p:3000},{n:"Prednisolone 5mg",p:5000},{n:"pregabline 150mg",p:3000},{n:"Promethazine 25mg",p:6000},{n:"Quinine inj",p:1200},{n:"Quinine tap (100T)",p:17000},{n:"Salbutamol 4mg",p:4500},{n:"Salbutamol inhaler",p:6500},{n:"Sildenafil 100mg",p:1000},{n:"Spironolactone 25 mg",p:2500},{n:"tetracycline skin",p:3300},{n:"Tobramycin Eye Drop",p:4500},{n:"Vancomycin 1mg inj",p:6000},{n:"Vildagliptin 500",p:3000},{n:"Vominore tab",p:2000},{n:"Diclofenac sodium 75 inj",p:4000},{n:"Water for inj 10ML",p:12000},{n:"Zinc Sulphate Syrup",p:2500}];

    let cart = [];
    let isBrowsing = false;

    function toggleBrowse() {
        const btn = document.getElementById('browseBtn');
        if (!isBrowsing) {
            renderItems(masterData);
            btn.innerText = "إغلاق"; btn.style.background = "var(--accent)";
            isBrowsing = true;
        } else { resetAll(); }
    }

    function resetAll() {
        document.getElementById('itemsWrapper').innerHTML = `<div style="text-align:center; padding:15px; color:#bbb; font-size: 0.75rem;">الأصناف هنا..</div>`;
        document.getElementById('itemSearch').value = "";
        document.getElementById('browseBtn').innerText = "تصفح";
        document.getElementById('browseBtn').style.background = "var(--info)";
        isBrowsing = false;
    }

    function filterItems() {
        const term = document.getElementById('itemSearch').value.trim().toLowerCase();
        if (term === "") { resetAll(); return; }
        const filtered = masterData.filter(i => i.n.toLowerCase().includes(term));
        renderItems(filtered);
        document.getElementById('browseBtn').innerText = "إغلاق";
        document.getElementById('browseBtn').style.background = "var(--accent)";
        isBrowsing = true;
    }

    function renderItems(data) {
        const wrapper = document.getElementById("itemsWrapper");
        wrapper.innerHTML = "";
        data.forEach((item, index) => {
            const div = document.createElement("div");
            div.className = "item-row";
            const qId = `q-${index}`;
            div.innerHTML = `
                <div class="item-info" onclick="addToCart('${item.n}', ${item.p}, '${qId}')">
                    <span>${item.n} - <b>${item.p}</b></span>
                </div>
                <input type="number" id="${qId}" class="qty-input" value="1" min="1">
            `;
            wrapper.appendChild(div);
        });
    }

    function addToCart(name, price, qId) {
        const qty = parseInt(document.getElementById(qId).value) || 1;
        const exists = cart.find(i => i.n === name);
        if(exists) exists.q += qty; else cart.push({ n: name, q: qty, p: price });
        updateInvoice();
    }

    function updateInvoice() {
        const tbody = document.getElementById('cartItems');
        tbody.innerHTML = "";
        let total = 0;
        cart.forEach((item, index) => {
            const sum = item.q * item.p;
            total += sum;
            tbody.innerHTML += `<tr>
                <td style="text-align:right;">${item.n}</td>
                <td>${item.p}</td>
                <td><input type="number" value="${item.q}" onchange="editQty(${index}, this.value)" style="width:30px"></td>
                <td>${sum}</td>
                <td onclick="removeItem(${index})" style="color:red; cursor:pointer">✕</td>
            </tr>`;
        });
        document.getElementById('grandTotal').innerText = `الإجمالي: ${total.toLocaleString()} SDG`;
    }

    function editQty(index, val) { if(val > 0) { cart[index].q = parseInt(val); updateInvoice(); } }
    function removeItem(index) { cart.splice(index, 1); updateInvoice(); }
    function openStaffModal() { if(cart.length > 0) document.getElementById('staffModal').style.display='flex'; else alert('الفاتورة فارغة'); }

    function sendToWA(phone, staff) {
        let msg = `*طلب جديد*\n*المستلم:* ${staff}\n---\n`;
        cart.forEach(i => msg += `• ${i.n} [${i.q}] = ${i.q*i.p} SDG\n`);
        msg += `---\n*${document.getElementById('grandTotal').innerText}*`;
        window.open(`https://wa.me/${phone}?text=${encodeURIComponent(msg)}`);
    }
</script>
</body>
</html>
